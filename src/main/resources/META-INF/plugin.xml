<idea-plugin require-restart="true">
    <id>com.github.ixmoyren.typilot</id>
    <name>typilot</name>
    <vendor>ixmoyren</vendor>
    <description><![CDATA[
        <p><b>typilot</b> provides comprehensive Typst language support for JetBrains IDEs.</p>
        <ul>
            <li><b>Rich Language Intelligence</b> — code completion, diagnostics, goto-definition, find references, rename, folding, signature help, and more via the <a href="https://github.com/Myriad-Dreamin/tinymist">tinymist</a> LSP server, automatically located or downloaded.</li>
            <li><b>Live Preview</b> — side-by-side JCEF-based preview that updates as you type, with invert colors support.</li>
            <li><b>Full PSI & Syntax Highlighting</b> — WASM-based lexer and parser covering all Typst syntax (markup, math, code) with lexical and semantic highlighting, rainbow brackets, and customizable color schemes.</li>
            <li><b>Export PDF</b> — export the current Typst document to PDF via editor actions, context menus, or CodeLens inline buttons.</li>
            <li><b>Language Injection</b> — syntax highlighting for 90+ languages inside Typst raw code blocks (e.g. ```rust).</li>
            <li><b>Comprehensive Settings</b> — full tinymist configuration schema (output, formatting, preview, completion, linting, etc.) and auto-setup that finds or downloads the server binary.</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <depends>com.intellij.java</depends>
    <depends>com.redhat.devtools.lsp4ij</depends>

    <resource-bundle>messages.TypilotBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Typst"
                  implementationClass="com.github.ixmoyren.typilot.language.TypstFileType"
                  fieldName="INSTANCE"
                  language="Typst"
                  extensions="typ"/>

        <fileEditorProvider implementation="com.github.ixmoyren.typilot.preview.TypstTextEditorWithPreviewProvider"/>

        <lang.parserDefinition
                language="Typst"
                implementationClass="com.github.ixmoyren.typilot.psi.TypstParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="Typst"
                implementationClass="com.github.ixmoyren.typilot.highlight.TypstSyntaxHighlighterFactory"/>

        <lang.foldingBuilder
                language="Typst"
                implementationClass="com.redhat.devtools.lsp4ij.features.foldingRange.LSPFoldingRangeBuilder"
                order="first"/>

        <lang.psiStructureViewFactory language="Typst"
                                      implementationClass="com.redhat.devtools.lsp4ij.features.documentSymbol.LSPDocumentSymbolStructureViewFactory"
                                      order="first"/>

        <codeBlockProvider language="Typst"
                           implementationClass="com.redhat.devtools.lsp4ij.features.codeBlockProvider.LSPCodeBlockProvider"
                           order="first"/>

        <codeInsight.parameterInfo
                language="Typst"
                implementationClass="com.redhat.devtools.lsp4ij.features.signatureHelp.LSPParameterInfoHandler"/>

        <annotator
                language="Typst"
                implementationClass="com.github.ixmoyren.typilot.highlight.TypstHighlightAnnotator"/>

        <colorSettingsPage
                implementation="com.github.ixmoyren.typilot.highlight.TypstColorSettingsPage"/>
        <additionalTextAttributes scheme="High contrast" file="colors/high-contrast.xml"/>
        <additionalTextAttributes scheme="Light" file="colors/light.xml"/>
        <additionalTextAttributes scheme="IntelliJ Light" file="colors/light.xml"/>
        <additionalTextAttributes scheme="Darcula" file="colors/darcula.xml"/>

        <multiHostInjector implementation="com.github.ixmoyren.typilot.injection.TypstRawBlockInjector"/>

        <lang.elementManipulator
                implementationClass="com.github.ixmoyren.typilot.injection.TypstRawBlockManipulator"
                forClass="com.example.TypstRawBlockPsiElement"/>

        <lang.commenter language="Typst"
                        implementationClass="com.github.ixmoyren.typilot.language.TypstCommenter"/>

        <postStartupActivity implementation="com.github.ixmoyren.typilot.StartupActivity"/>

        <applicationService
                serviceImplementation="com.github.ixmoyren.typilot.settings.TinymistSettings"/>
        <applicationConfigurable
                parentId="tools"
                instance="com.github.ixmoyren.typilot.settings.TinymistConfigurable"
                id="com.github.pndv.typstrenderer.settings.TypstConfigurable"
                bundle="messages.TypilotBundle" key="settings.displayName"/>

        <notificationGroup id="Typst" displayType="BALLOON" bundle="messages.TypilotBundle"
                           key="notification.group.typilot"/>
    </extensions>

    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="tinymistServer"
                name="Typst Language Server"
                factoryClass="com.github.ixmoyren.typilot.lsp.TypstLanguageServerFactory">
            <description><![CDATA[
            Provides Typst language intelligence via the tinymist LSP.
            ]]></description>
        </server>
        <languageMapping language="Typst"
                         serverId="tinymistServer"
                         languageId="typst"/>

        <fileNamePatternMapping patterns="*.typ"
                                serverId="tinymistServer"
                                languageId="typst"/>
    </extensions>

    <actions resource-bundle="messages.TypilotBundle">
        <action id="Typst.Help"
                class="com.github.ixmoyren.typilot.actions.TypstHelpAction"
                icon="AllIcons.Actions.Help">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl shift H"/>
        </action>

        <action id="Tinymist.ExportPdf"
                class="com.github.ixmoyren.typilot.actions.TinymistExportPdfAction"
                icon="AllIcons.General.Export">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
