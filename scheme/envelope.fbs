table Token {
  kind:ubyte;
  start:uint32;
  end:uint32;
  is_leaf:bool;
  is_error:bool;
  children_count:uint32;
  error_message:string;
}

table TokenList {
  tokens:[Token];
}

struct Node {
  start:uint32;
  end:uint32;
  kind:uint8;
}

table NodeList {
  nodes:[Node];
}

root_type TokenList;
