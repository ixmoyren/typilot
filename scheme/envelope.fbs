struct Token {
  kind:ubyte;
  start:uint32;
  end:uint32;
}

table TokenList {
  tokens:[Token];
}

table ASTNode {
  kind:ubyte;
  start:uint32;
  end:uint32;
  is_leaf:bool;
  is_error:bool;
  children_count:uint32;
  error_message:string;
}

table ASTNodeList {
  nodes:[ASTNode];
}

root_type ASTNodeList;
